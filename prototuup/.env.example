# Demo-režiimis (vaikevalik) API võtmeid ei ole vaja — backend tagastab
# salvestatud näidisvastuse. Selle faili saab täita, kui soovid proovida ka
# päris LLM-mudeleid (Claude või GPT). Kopeeri see faili .env ja muuda
# vajalikke ridu. Fail .env EI tohi minna versioonihaldusesse.

# Anthropic Claude API võti — nõutav AINULT siis, kui valid mudeliks claude-*.
# Saad genereerida aadressilt https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API võti — nõutav AINULT siis, kui valid mudeliks gpt-*.
# OPENAI_API_KEY=

# Logimistase: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Lubatud frontendi päritolud (komaeraldatud)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
