# Kopeeri failiks .env ja täida konkreetsete väärtustega.
# .env fail EI tohi minna versioonihaldusesse.

# Anthropic Claude API võti – nõutav, kui kasutad mudelit claude-*.
# Saad genereerida aadressilt https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API võti – nõutav ainult juhul, kui soovid kasutada mudelit gpt-*.
# Vali tühjaks jätmine kui OpenAI mudelite tuge ei vaja.
OPENAI_API_KEY=

# Logimistase: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Lubatud frontendi päritolud (komaeraldatud)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
